# Keep the build context small and never ship secrets / junk into the image.
.venv/
.git/
.gitignore
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Secrets — provided at runtime, never baked in
.env

# Not needed at runtime (index is pre-built and copied explicitly).
# Exclude only the runtime DBs in data/ (incl. -wal/-shm) — but NOT chroma_db/chroma.sqlite3,
# which IS the search index and must be baked in.
*.pdf
data/*.sqlite*

# Docs / meta
*.md
Dockerfile
.dockerignore
