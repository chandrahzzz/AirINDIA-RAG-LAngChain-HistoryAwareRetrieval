# Secrets — never commit
.env

# Python
__pycache__/
*.py[cod]
venv/
.venv/
env/
*.egg-info/

# Vector store / search index (built locally, never committed)
chroma_db/
*.faiss
*.pkl

# Databases / runtime state — never commit (chat history, graph state, leads, vector DB)
